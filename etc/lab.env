# Optional overrides for the toolkit.
#
# Leave these unset unless you intentionally want parts of the tree to live in
# different locations.
#
LAB_ROLE=builder
LAB_RUNTIME_TARGET=local-usb
#
# Example:
# LAB_LOGS_DIR=/run/media/ao/labvault/runtime/shared/logs
# LAB_REPORTS_DIR=/run/media/ao/labvault/runtime/shared/reports
#
# Runtime releases set LAB_PERSIST_DIR automatically to a shared directory next
# to the release store. Override it only when the runtime state needs to live on
# another mounted volume.
