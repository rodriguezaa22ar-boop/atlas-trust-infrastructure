{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/generic-external-event.v1.schema.json",
  "title": "Generic External Event v1",
  "type": "object",
  "required": [
    "schema_version",
    "adapter_id",
    "event_id",
    "observed_at",
    "event_type",
    "actor",
    "source_ref",
    "subject",
    "evidence_refs",
    "artifact_refs",
    "approval_refs",
    "metadata_only",
    "raw_artifacts_embedded",
    "known_limitations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "generic.external_event.v1"
    },
    "adapter_id": {
      "type": "string",
      "const": "generic.external_event.v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "source_ref": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "required": [
        "type",
        "ref"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "approval_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata_only": {
      "type": "boolean",
      "const": true
    },
    "raw_artifacts_embedded": {
      "type": "boolean",
      "const": false
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
