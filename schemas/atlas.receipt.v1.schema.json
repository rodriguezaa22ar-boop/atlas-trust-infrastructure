{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/atlas.receipt.v1.schema.json",
  "title": "Atlas Receipt v1",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "timestamp",
    "metadata_only",
    "raw_artifacts_embedded",
    "action",
    "actor",
    "subject",
    "evidence_refs",
    "artifact_refs",
    "approval_refs",
    "prev_hash",
    "event_hash",
    "receipt_hash",
    "known_limitations",
    "verifier"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "atlas.receipt.v1"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "metadata_only": {
      "type": "boolean",
      "const": true
    },
    "raw_artifacts_embedded": {
      "type": "boolean",
      "const": false
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "object",
      "required": [
        "type",
        "ref"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifact_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "approval_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prev_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "receipt_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verifier": {
      "type": "object",
      "required": [
        "name",
        "schema"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "const": "atlas receipt verify"
        },
        "schema": {
          "type": "string",
          "const": "schemas/atlas.receipt.v1.schema.json"
        }
      }
    }
  }
}
