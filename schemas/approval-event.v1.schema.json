{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/approval-event.v1.schema.json",
  "title": "Atlas Approval Event v1",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "timestamp",
    "metadata_only",
    "requester",
    "capability",
    "capability_class",
    "workflow",
    "risk",
    "scope",
    "approver",
    "expiry",
    "rationale",
    "rollback_plan",
    "evidence_refs",
    "status",
    "policy_decision"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "atlas.approval_event.v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "approval_requested",
        "approval_approved",
        "approval_expired"
      ]
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "metadata_only": {
      "type": "boolean",
      "const": true
    },
    "requester": {
      "type": "string",
      "minLength": 1
    },
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "capability_class": {
      "type": "string",
      "enum": [
        "bounded_exec",
        "mutate",
        "admin"
      ]
    },
    "workflow": {
      "type": "string",
      "minLength": 1
    },
    "risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "scope": {
      "type": "object",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "approver": {
      "type": "string",
      "minLength": 1
    },
    "expiry": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "rollback_plan": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "requested",
        "approved",
        "expired"
      ]
    },
    "policy_decision": {
      "type": "object",
      "required": [
        "decision",
        "policy_ref",
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "approval_required",
            "allow"
          ]
        },
        "policy_ref": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "original_event_id": {
      "type": "string",
      "minLength": 1
    },
    "expired_by": {
      "type": "string",
      "minLength": 1
    },
    "expire_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
