{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/run-event.v1.schema.json",
  "title": "Atlas Run Event v1",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "timestamp",
    "metadata_only",
    "actor",
    "capability",
    "decision",
    "status",
    "evidence_refs",
    "prev_hash",
    "event_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "atlas.run_event.v1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "metadata_only": {
      "type": "boolean",
      "const": true
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "approval_required",
        "unsupported",
        "not_in_scope"
      ]
    },
    "decision_ref": {
      "type": "string"
    },
    "approval_ref": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "requested",
        "approved",
        "running",
        "pass",
        "fail",
        "not-ready",
        "expired",
        "skipped"
      ]
    },
    "input_hash": {
      "type": "string"
    },
    "output_hash": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prev_hash": {
      "type": "string",
      "minLength": 1
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
