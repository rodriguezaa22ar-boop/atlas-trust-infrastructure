#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

shellcheck -x \
	"$ROOT/bin/intelctl" \
	"$ROOT/bin/labctl" \
	"$ROOT/bin/dev-lint" \
	"$ROOT/bin/dev-fmt" \
	"$ROOT/bin/dev-test" \
	"$ROOT/bin/dev-stress" \
	"$ROOT/bin/dev-qa" \
	"$ROOT/lib/common.sh" \
	"$ROOT/lib/intel.sh" \
	"$ROOT/tools"/*/bin/*

printf 'lint: ok\n'
