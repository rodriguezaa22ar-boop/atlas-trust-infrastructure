#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
atlas_libs=()

if compgen -G "$ROOT/tools/atlas/lib/*.sh" >/dev/null; then
	atlas_libs=("$ROOT"/tools/atlas/lib/*.sh)
fi

shfmt -w \
	"$ROOT/bin/intelctl" \
	"$ROOT/bin/labctl" \
	"$ROOT/bin/dev-lint" \
	"$ROOT/bin/dev-fmt" \
	"$ROOT/bin/dev-test" \
	"$ROOT/lib/common.sh" \
	"$ROOT/lib/intel.sh" \
	"${atlas_libs[@]}" \
	"$ROOT/tools"/*/bin/*

printf 'format: ok\n'
