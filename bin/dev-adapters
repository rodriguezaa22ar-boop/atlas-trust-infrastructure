#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
REGISTRY="${1:-$ROOT/adapters/registry.yaml}"
CAPABILITIES="$ROOT/capabilities.yaml"

fail() {
  printf 'adapters: fail %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command $1"
}

first_jq() {
  jq -r "[$1][0] // empty" "$REGISTRY"
}

require_command jq
require_command sort
require_command uniq

[ -f "$REGISTRY" ] || fail "missing adapters/registry.yaml"
[ -f "$CAPABILITIES" ] || fail "missing capabilities.yaml"

jq -e . "$REGISTRY" >/dev/null 2>&1 || fail "invalid registry JSON-compatible YAML"
jq -e . "$CAPABILITIES" >/dev/null 2>&1 || fail "invalid capabilities.yaml JSON-compatible YAML"

jq -e '.schema_version == "atlas.adapter_registry.v1"' "$REGISTRY" >/dev/null || fail "missing schema_version"
jq -e '.default_mode == "deny"' "$REGISTRY" >/dev/null || fail "default_mode must be deny"
jq -e '.status == "draft"' "$REGISTRY" >/dev/null || fail "status must be draft"
jq -e '.live_integrations_enabled == false' "$REGISTRY" >/dev/null || fail "live integrations must be disabled"
jq -e '.metadata_only == true' "$REGISTRY" >/dev/null || fail "registry must be metadata_only"
jq -e '.adapters | type == "array" and length > 0' "$REGISTRY" >/dev/null || fail "missing adapters"

missing_id="$(first_jq '.adapters[] | select((.id // "") == "") | "missing adapter id"')"
[ -z "$missing_id" ] || fail "$missing_id"

duplicate_id="$(jq -r '.adapters[].id' "$REGISTRY" | sort | uniq -d | head -n 1)"
[ -z "$duplicate_id" ] || fail "duplicate id $duplicate_id"

bad_mode="$(
  # shellcheck disable=SC2016 # jq program uses jq variables, not shell expansion.
  first_jq '
    .adapters[]
    | . as $adapter
    | select((["read", "import", "verify", "export", "propose"] | index($adapter.mode)) | not)
    | "\(.id) mode \(.mode // "missing")"
  '
)"
[ -z "$bad_mode" ] || fail "unsupported adapter mode $bad_mode"

mutating_mode="$(first_jq '.adapters[] | select(.mode == "mutate") | .id')"
[ -z "$mutating_mode" ] || fail "mutate mode is not allowed $mutating_mode"

missing_field="$(
  first_jq '
    .adapters[]
    | select(
        ((.title // "") == "")
        or ((.status // "") == "")
        or ((.mode // "") == "")
        or ((.systems | type) != "array" or (.systems | length) == 0)
        or ((.resources | type) != "array" or (.resources | length) == 0)
        or ((.effects | type) != "array" or (.effects | length) == 0)
        or (has("approval") | not)
        or ((.secrets_policy // "") == "")
        or ((.forbidden_inputs | type) != "array")
        or ((.test_fixtures | type) != "array" or (.test_fixtures | length) == 0)
        or ((.known_limitations | type) != "array" or (.known_limitations | length) == 0)
      )
    | .id
  '
)"
[ -z "$missing_field" ] || fail "missing required field $missing_field"

missing_capabilities="$(first_jq '.adapters[] | select((.capabilities | type) != "array" or (.capabilities | length) == 0) | .id')"
[ -z "$missing_capabilities" ] || fail "missing capabilities $missing_capabilities"

unknown_capability="$(
  jq -n -r \
    --slurpfile registry "$REGISTRY" \
    --slurpfile capabilities "$CAPABILITIES" '
      ($capabilities[0].capabilities | map(.id)) as $known
      | [
          $registry[0].adapters[]
          | . as $adapter
          | .capabilities[] as $capability
          | select(($known | index($capability)) | not)
          | "\($adapter.id) \($capability)"
        ][0] // empty
    '
)"
[ -z "$unknown_capability" ] || fail "unknown capability $unknown_capability"

missing_evidence="$(first_jq '.adapters[] | select((.evidence.emits | type) != "array" or (.evidence.emits | length) == 0) | .id')"
[ -z "$missing_evidence" ] || fail "missing evidence.emits $missing_evidence"

not_metadata_only="$(first_jq '.adapters[] | select(.metadata_only != true) | .id')"
[ -z "$not_metadata_only" ] || fail "adapter must be metadata_only $not_metadata_only"

live_adapter="$(first_jq '.adapters[] | select(.live_integration != false) | .id')"
[ -z "$live_adapter" ] || fail "live integration is not allowed $live_adapter"

unsafe_proposal="$(
  first_jq '
    .adapters[]
    | select(.mode == "propose" and (.approval == "none" or (.live_integration != false)))
    | .id
  '
)"
[ -z "$unsafe_proposal" ] || fail "proposal adapters require approval and no live integration $unsafe_proposal"

unsafe_output="$(
  # shellcheck disable=SC2016 # jq program uses jq variables, not shell expansion.
  first_jq '
    .adapters[]
    | . as $adapter
    | .evidence.emits[]
    | select(test("raw_log|secret|private_key|token|authorization_header|request_body|response_body|packet_capture|raw_prompt|raw_model_output|customer_data|payment_data|private_business_record"; "i"))
    | $adapter.id
  '
)"
[ -z "$unsafe_output" ] || fail "unsafe evidence output $unsafe_output"

absolute_fixture="$(
  # shellcheck disable=SC2016 # jq program uses jq variables, not shell expansion.
  first_jq '.adapters[] | . as $adapter | .test_fixtures[] | select(startswith("/") or contains("..")) | $adapter.id'
)"
[ -z "$absolute_fixture" ] || fail "test fixture path must be relative $absolute_fixture"

printf 'adapters: ok\n'
