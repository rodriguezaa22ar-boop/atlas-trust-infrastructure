#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
WORKFLOWS="${1:-$ROOT/approval/workflows.yaml}"
PLANE="${2:-$ROOT/approval/approval-plane.yaml}"
SCHEMA="$ROOT/schemas/approval-event.v1.schema.json"
ATLAS="$ROOT/tools/atlas/bin/atlas"

fail() {
  printf 'approval: fail %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command $1"
}

first_jq() {
  jq -r "[$1][0] // empty" "$WORKFLOWS"
}

require_command jq
require_command grep
require_command sort
require_command uniq

[ -f "$WORKFLOWS" ] || fail "missing approval/workflows.yaml"
[ -f "$PLANE" ] || fail "missing approval/approval-plane.yaml"
[ -f "$SCHEMA" ] || fail "missing schemas/approval-event.v1.schema.json"
[ -x "$ATLAS" ] || fail "missing atlas CLI"

jq -e . "$WORKFLOWS" >/dev/null 2>&1 || fail "invalid workflows JSON-compatible YAML"
jq -e . "$PLANE" >/dev/null 2>&1 || fail "invalid approval plane JSON-compatible YAML"
jq -e . "$SCHEMA" >/dev/null 2>&1 || fail "invalid approval event schema JSON"

jq -e '
  .schema_version == "atlas.approval_plane.v1" and
  .status == "draft" and
  .approval_engine_enabled == false and
  .live_workflows_enabled == false and
  .automatic_approval_enabled == false and
  .break_glass_execution_enabled == false and
  .metadata_only == true and
  .default_state == "approval_required_when_policy_requires" and
  (.approval_states | type == "array" and length > 0) and
  (.approval_workflows | type == "array" and length > 0)
' "$PLANE" >/dev/null || fail "invalid approval plane draft"

for state in \
  not_required \
  required \
  requested \
  approved \
  rejected \
  expired \
  revoked \
  stale \
  escalated \
  unsupported \
  boundary_violation; do
  jq -e --arg state "$state" '.approval_states | index($state)' "$PLANE" >/dev/null ||
    fail "missing approval state $state"
done

for workflow in \
  atlas.release_exception_review \
  atlas.ticket_transition_proposal_review \
  atlas.cloud_change_proposal_review \
  atlas.ai_agent_tool_execution_review \
  atlas.production_readiness_exception_review \
  atlas.business_flow_sensitive_change_review \
  atlas.public_export_boundary_review \
  atlas.break_glass_documentation_review; do
  jq -e --arg workflow "$workflow" 'any(.approval_workflows[]; .id == $workflow)' "$PLANE" >/dev/null ||
    fail "missing approval plane workflow $workflow"
done

duplicate_plane_workflow="$(jq -r '.approval_workflows[].id' "$PLANE" | sort | uniq -d | head -n 1)"
[ -z "$duplicate_plane_workflow" ] || fail "duplicate approval plane workflow $duplicate_plane_workflow"

missing_plane_field="$(
  jq -r '
    .approval_workflows[]
    | select(
        ((.id // "") == "")
        or ((.title // "") == "")
        or ((.status // "") == "")
        or ((.purpose // "") == "")
        or ((.triggering_capabilities | type) != "array" or (.triggering_capabilities | length) == 0)
        or ((.triggering_adapters | type) != "array")
        or ((.applies_to | type) != "array" or (.applies_to | length) == 0)
        or (has("approval_required") | not)
        or (has("minimum_reviewers") | not)
        or ((.approver_roles | type) != "array" or (.approver_roles | length) == 0)
        or ((.expiration | type) != "object")
        or ((.reapproval_triggers | type) != "array" or (.reapproval_triggers | length) == 0)
        or ((.decision_outputs | type) != "array" or (.decision_outputs | length) == 0)
        or ((.evidence_required | type) != "array" or (.evidence_required | length) == 0)
        or (has("metadata_only") | not)
        or (has("live_execution") | not)
        or (has("automatic_execution") | not)
        or ((.break_glass | type) != "object")
        or ((.known_limitations | type) != "array" or (.known_limitations | length) == 0)
      )
    | .id // "unnamed"
  ' "$PLANE" | head -n 1
)"
[ -z "$missing_plane_field" ] || fail "missing approval plane workflow field $missing_plane_field"

live_plane_workflow="$(jq -r '.approval_workflows[] | select(.live_execution != false) | .id' "$PLANE" | head -n 1)"
[ -z "$live_plane_workflow" ] || fail "live approval workflow is not allowed $live_plane_workflow"

automatic_plane_workflow="$(jq -r '.approval_workflows[] | select(.automatic_execution != false) | .id' "$PLANE" | head -n 1)"
[ -z "$automatic_plane_workflow" ] || fail "automatic approval workflow is not allowed $automatic_plane_workflow"

executing_break_glass_workflow="$(jq -r '.approval_workflows[] | select(.break_glass.execution_enabled != false) | .id' "$PLANE" | head -n 1)"
[ -z "$executing_break_glass_workflow" ] || fail "break-glass execution is not allowed $executing_break_glass_workflow"

not_metadata_only_workflow="$(jq -r '.approval_workflows[] | select(.metadata_only != true) | .id' "$PLANE" | head -n 1)"
[ -z "$not_metadata_only_workflow" ] || fail "approval workflow must be metadata_only $not_metadata_only_workflow"

for forbidden in \
  "raw logs" \
  "secrets" \
  "private keys" \
  "tokens" \
  "Authorization headers" \
  "request bodies" \
  "response bodies" \
  "packet captures" \
  "raw prompts" \
  "raw model outputs" \
  "customer data" \
  "payment data" \
  "private business records" \
  "unredacted evidence bodies"; do
  jq -e --arg forbidden "$forbidden" '.forbidden_inputs | index($forbidden)' "$PLANE" >/dev/null ||
    fail "missing forbidden approval input $forbidden"
done

jq -e '
  any(.approval_workflows[]; .id == "atlas.ai_agent_tool_execution_review" and any(.known_limitations[]; contains("AI agents are requesters, not authorities"))) and
  any(.approval_workflows[]; .id == "atlas.break_glass_documentation_review" and .break_glass.allowed == true and .break_glass.execution_enabled == false and any(.known_limitations[]; contains("documentation and review only"))) and
  any(.approval_workflows[]; .id == "atlas.cloud_change_proposal_review" and .live_execution == false and any(.known_limitations[]; contains("proposal-only"))) and
  any(.approval_workflows[]; .id == "atlas.ticket_transition_proposal_review" and .live_execution == false and any(.known_limitations[]; contains("proposal-only"))) and
  any(.approval_workflows[]; .id == "atlas.public_export_boundary_review" and any(.known_limitations[]; contains("private-marker and metadata-only boundaries"))) and
  any(.approval_workflows[]; .id == "atlas.business_flow_sensitive_change_review" and any(.known_limitations[]; contains("Private business records")) and any(.known_limitations[]; contains("Payment data")))
' "$PLANE" >/dev/null || fail "missing approval plane safety workflow wording"

unsafe_plane_text="$(
  jq -r '.. | strings?' "$PLANE" |
    grep -Ei 'approval engine implemented|approval workflow execution implemented|automatic approval execution implemented|break-glass execution implemented|live integration enabled|API calls enabled|webhooks enabled|network collectors enabled|credentials configured|mutation authority added|guaranteed compliance|certified compliant|legally compliant|external audit complete|enterprise deployment approved|production approval implemented|complete event coverage: (true|ready|implemented)|runtime safety proven|model correctness proven|artifact correctness guaranteed|actions outside Atlas cannot happen|Atlas grants authorization' |
    head -n 1 || true
)"
[ -z "$unsafe_plane_text" ] || fail "unsafe approval plane claim $unsafe_plane_text"

jq -e '
  .schema_version == "atlas.approval_workflows.v1" and
  .version == 1 and
  .metadata_only == true and
  .default_mode == "approval_required"
' "$WORKFLOWS" >/dev/null || fail "invalid approval workflow header"

jq -e '
  .required_event_fields == [
    "requester",
    "capability",
    "risk",
    "scope",
    "approver",
    "expiry",
    "rationale",
    "rollback_plan",
    "evidence_refs"
  ]
' "$WORKFLOWS" >/dev/null || fail "required event fields changed"

jq -e '.approval_states == ["requested", "approved", "expired"]' "$WORKFLOWS" >/dev/null ||
  fail "approval states changed"
jq -e '.workflows | type == "array" and length > 0' "$WORKFLOWS" >/dev/null ||
  fail "missing workflows"

duplicate_id="$(jq -r '.workflows[].id' "$WORKFLOWS" | sort | uniq -d | head -n 1)"
[ -z "$duplicate_id" ] || fail "duplicate workflow id $duplicate_id"

missing_field="$(
  first_jq '
    .workflows[]
    | select(
        ((.id // "") == "")
        or ((.applies_to_classes | type) != "array")
        or ((.applies_to_classes | length) == 0)
        or ((.min_risk // "") == "")
        or (.approval_required != true)
        or (.approver_required != true)
        or (.expiry_required != true)
        or (.rationale_required != true)
        or (.rollback_plan_required != true)
        or (.evidence_refs_required != true)
        or (.changed_diff_requires_reapproval != true)
        or ((.owner // "") == "")
      )
    | .id // "unnamed"
  '
)"
[ -z "$missing_field" ] || fail "missing required workflow field $missing_field"

unknown_class="$(
  jq -r '
    [
      .workflows[]
      | . as $workflow
      | $workflow.applies_to_classes[]
      | select((["bounded_exec", "mutate", "admin"] | index(.)) | not)
      | "\($workflow.id) \(.)"
    ][0] // empty
  ' "$WORKFLOWS"
)"
[ -z "$unknown_class" ] || fail "unknown workflow class $unknown_class"

bad_risk="$(
  # shellcheck disable=SC2016 # jq program must receive $workflow, not shell-expanded text.
  first_jq '
    .workflows[]
    | . as $workflow
    | select((["low", "medium", "high", "critical"] | index($workflow.min_risk)) | not)
    | "\($workflow.id) \($workflow.min_risk // "missing")"
  '
)"
[ -z "$bad_risk" ] || fail "unknown workflow risk $bad_risk"

jq -e '
  any(.workflows[]; (.applies_to_classes | index("bounded_exec"))) and
  any(.workflows[]; (.applies_to_classes | index("admin")))
' "$WORKFLOWS" >/dev/null || fail "missing bounded_exec or admin workflow"

jq -e '
  .title == "Atlas Approval Event v1" and
  (.required | index("requester")) and
  (.required | index("capability")) and
  (.required | index("risk")) and
  (.required | index("scope")) and
  (.required | index("approver")) and
  (.required | index("expiry")) and
  (.required | index("rationale")) and
  (.required | index("rollback_plan")) and
  (.required | index("evidence_refs"))
' "$SCHEMA" >/dev/null || fail "approval event schema missing required fields"

event="$(
  "$ATLAS" approval request atlas.agent.tool.exec \
    --scope agent-runtime \
    --risk medium \
    --requester atlas-dev \
    --approver reviewer \
    --expiry 2099-12-31T00:00:00Z \
    --rationale "bounded tool execution request" \
    --rollback-plan "remove generated sandbox output" \
    --evidence-ref policy/tests/decisions.v1.json \
    --json
)" || fail "approval request command failed"

printf '%s\n' "$event" | jq -e '
  .schema_version == "atlas.approval_event.v1" and
  .event_type == "approval_requested" and
  .metadata_only == true and
  .capability == "atlas.agent.tool.exec" and
  .capability_class == "bounded_exec" and
  .workflow == "policy-threshold-human-review" and
  .risk == "medium" and
  .status == "requested" and
  .policy_decision.decision == "approval_required" and
  (.evidence_refs | length == 1)
' >/dev/null || fail "approval request output invalid"

if ! verify_output="$(printf '%s\n' "$event" | "$ATLAS" approval verify - 2>&1)"; then
  verify_output="${verify_output#error: }"
  fail "$verify_output"
fi
[ "$verify_output" = "approval: ok" ] || fail "unexpected approval verify output $verify_output"

approved_event="$(
  printf '%s\n' "$event" |
    "$ATLAS" approval approve - --actor reviewer --json
)" || fail "approval approve command failed"

printf '%s\n' "$approved_event" | jq -e '
  .schema_version == "atlas.approval_event.v1" and
  .event_type == "approval_approved" and
  .status == "approved" and
  .approved_by == "reviewer" and
  .policy_decision.decision == "allow" and
  (.original_event_id | length > 0)
' >/dev/null || fail "approval approve output invalid"

if ! verify_approved_output="$(printf '%s\n' "$approved_event" | "$ATLAS" approval verify - 2>&1)"; then
  verify_approved_output="${verify_approved_output#error: }"
  fail "$verify_approved_output"
fi
[ "$verify_approved_output" = "approval: ok" ] || fail "unexpected approved approval verify output $verify_approved_output"

expired_event="$(
  printf '%s\n' "$event" |
    "$ATLAS" approval expire - --reason "approval window closed" --actor atlas-dev --json
)" || fail "approval expire command failed"

printf '%s\n' "$expired_event" | jq -e '
  .schema_version == "atlas.approval_event.v1" and
  .event_type == "approval_expired" and
  .status == "expired" and
  .expired_by == "atlas-dev" and
  .expire_reason == "approval window closed" and
  (.original_event_id | length > 0)
' >/dev/null || fail "approval expire output invalid"

if ! verify_expired_output="$(printf '%s\n' "$expired_event" | "$ATLAS" approval verify - 2>&1)"; then
  verify_expired_output="${verify_expired_output#error: }"
  fail "$verify_expired_output"
fi
[ "$verify_expired_output" = "approval: ok" ] || fail "unexpected expired approval verify output $verify_expired_output"

if output="$("$ATLAS" approval request atlas.status.read \
  --scope runtime \
  --risk low \
  --requester atlas-dev \
  --approver reviewer \
  --expiry 2099-12-31T00:00:00Z \
  --rationale "read status" \
  --rollback-plan "none" \
  --evidence-ref policy/tests/decisions.v1.json \
  --json 2>&1)"; then
  fail "read capability unexpectedly required approval"
else
  output="${output#error: }"
  [ "$output" = "approval not required for atlas.status.read" ] ||
    fail "unexpected read approval output $output"
fi

if output="$("$ATLAS" approval request atlas.agent.tool.exec \
  --scope agent-runtime \
  --risk medium \
  --requester atlas-dev \
  --approver reviewer \
  --expiry 2000-01-01T00:00:00Z \
  --rationale "expired request" \
  --rollback-plan "remove generated sandbox output" \
  --evidence-ref policy/tests/decisions.v1.json \
  --json 2>&1)"; then
  fail "expired approval request unexpectedly passed"
else
  output="${output#error: }"
  [ "$output" = "approval event expired" ] ||
    fail "unexpected expired approval output $output"
fi

if output="$("$ATLAS" approval request atlas.agent.tool.exec \
  --scope agent-runtime \
  --risk medium \
  --requester atlas-dev \
  --approver reviewer \
  --expiry 2099-12-31T00:00:00Z \
  --rationale "token=abc123" \
  --rollback-plan "remove generated sandbox output" \
  --evidence-ref policy/tests/decisions.v1.json \
  --json 2>&1)"; then
  fail "sensitive approval request unexpectedly passed"
else
  output="${output#error: }"
  [[ "$output" == approval\ event\ contains\ forbidden\ content\ marker:* ]] ||
    fail "unexpected sensitive approval output $output"
fi

printf 'approval: ok\n'
