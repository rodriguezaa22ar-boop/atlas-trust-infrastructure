#!/usr/bin/env bash

set -euo pipefail

required_commands=(
  bash
  git
  jq
  awk
  sed
  find
  sort
  wc
  mktemp
  cp
)

optional_commands=(
  bats
  shellcheck
  shfmt
  rg
  fd
  rsync
  tmux
  nix-shell
)

missing_required=0

check_command() {
  local name="$1"
  local path

  if path="$(command -v "$name" 2>/dev/null)"; then
    printf -- '- %s: ok %s\n' "$name" "$path"
  else
    printf -- '- %s: missing\n' "$name"
    return 1
  fi
}

printf 'Atlas Host Runtime Check\n'
printf '\nRequired Dependencies\n'

for command_name in "${required_commands[@]}"; do
  if ! check_command "$command_name"; then
    missing_required=$((missing_required + 1))
  fi
done

if command -v sha256sum >/dev/null 2>&1; then
  printf -- '- sha256: ok %s\n' "$(command -v sha256sum)"
elif command -v shasum >/dev/null 2>&1; then
  printf -- '- sha256: ok %s\n' "$(command -v shasum)"
else
  printf -- '- sha256: missing\n'
  missing_required=$((missing_required + 1))
fi

printf '\nOptional Dependencies\n'

for command_name in "${optional_commands[@]}"; do
  check_command "$command_name" || true
done

printf '\nRequired Missing: %s\n' "$missing_required"
if [ "$missing_required" -eq 0 ]; then
  printf 'Overall: ok\n'
else
  printf 'Overall: missing-required\n'
  exit 1
fi
