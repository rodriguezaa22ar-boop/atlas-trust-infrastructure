# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/report.sh
. "$TOOL_DIR/lib/report.sh"
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/readiness.sh
. "$TOOL_DIR/lib/readiness.sh"
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/advisor.sh
. "$TOOL_DIR/lib/advisor.sh"
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/doctor.sh
. "$TOOL_DIR/lib/doctor.sh"

load_config
ensure_layout

WIREMAP_BIN="${LAB_ATLAS_WIREMAP_BIN:-$LAB_ROOT/tools/wiremap/bin/wiremap}"
VECTOR_BIN="${LAB_ATLAS_VECTOR_BIN:-$LAB_ROOT/tools/vector/bin/vector}"
INTELCTL_BIN="${LAB_ATLAS_INTELCTL_BIN:-$LAB_ROOT/bin/intelctl}"
LABCTL_BIN="${LAB_ATLAS_LABCTL_BIN:-$LAB_ROOT/bin/labctl}"
ATLAS_STATE_DIR="$LAB_STATE_DIR/atlas"
ATLAS_ACTIVE_OP_FILE="$ATLAS_STATE_DIR/active.env"

mkdir -p "$ATLAS_STATE_DIR"

