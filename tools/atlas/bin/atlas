	load_active_operation
	atlas_scope_preflight "read-only" "vector" "$ATLAS_OP_TARGET" "review action outcomes"
	run_vector outcomes "$ATLAS_OP_TARGET"
}

cmd_op_brief() {
	load_active_operation

	ui_heading "Operation Brief"
	ui_rule
	print_operation_summary
	ui_rule
	ui_subheading "Operator Brief"
	atlas_brief_print_operation "$ATLAS_OP_TARGET"
	ui_rule
	print_tool_output_or_note "no surface summary available; run atlas op recon <workflow> first" run_vector target summary "$ATLAS_OP_TARGET"
	printf '\n'
	ui_subheading "Tracked Recon Runs"
	print_operation_entries "$ATLAS_OP_DIR/recon-runs" "no recon runs tracked yet"
	printf '\n'
	ui_subheading "Tracked Action Sessions"
	print_operation_entries "$ATLAS_OP_DIR/action-sessions" "no action sessions tracked yet"
	printf '\n'
	ui_subheading "Operation Evidence"
	print_operation_evidence_summary "$ATLAS_OP_TARGET" 8
	printf '\n'
	ui_subheading "Operation Findings"
	print_operation_findings_summary "$ATLAS_OP_TARGET" 8
	printf '\n'
	ui_subheading "Validation Plans"
	atlas_validation_print_table_for_target "$ATLAS_OP_TARGET" 8 "no operation validation plans recorded yet"
}

cmd_op_story() {
	local previous_suppression="${ATLAS_SUPPRESS_ACTIVE_OP_CONTEXT:-}"

	if [ "$#" -gt 0 ]; then
		load_atlas_operation "$1"
	else
		load_active_operation
	fi

	ui_heading "Operation Story"
	ui_rule
	print_operation_summary
	ui_rule
	ui_subheading "Operator Brief"
	atlas_brief_print_operation "$ATLAS_OP_TARGET"
	ui_rule
	ui_subheading "Tracked Recon Runs"
	print_operation_entries "$ATLAS_OP_DIR/recon-runs" "no recon runs tracked yet"
	printf '\n'
	ui_subheading "Tracked Action Sessions"
	print_operation_entries "$ATLAS_OP_DIR/action-sessions" "no action sessions tracked yet"
	printf '\n'
	ui_subheading "Operation Evidence"
	print_operation_evidence_summary "$ATLAS_OP_TARGET" 8
	printf '\n'
	ui_subheading "Operation Findings"
	print_operation_findings_summary "$ATLAS_OP_TARGET" 8
	printf '\n'
	ui_subheading "Validation Plans"
	atlas_validation_print_table_for_target "$ATLAS_OP_TARGET" 8 "no operation validation plans recorded yet"
	printf '\n'
	ATLAS_SUPPRESS_ACTIVE_OP_CONTEXT=1
	cmd_target_story "$ATLAS_OP_TARGET"
	ATLAS_SUPPRESS_ACTIVE_OP_CONTEXT="$previous_suppression"
}

cmd_op_next() {
	load_active_operation
	run_vector candidates "$ATLAS_OP_TARGET"
}

