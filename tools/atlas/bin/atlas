cmd_op_action_run() {
	need_args 1 "$#" "op action run <lane> [session-name]"
	local lane="$1"
	local session_name="${2:-}"
	local output
	local session_dir
	local link

	load_active_operation
	atlas_scope_preflight "safe-validation" "vector" "$ATLAS_OP_TARGET" "run action lane $lane"

	if [ -z "$session_name" ]; then
		session_name="$ATLAS_OP_NAME $lane"
	fi

	output="$(run_vector run "$lane" "$ATLAS_OP_TARGET" "$session_name")"
	printf '%s\n' "$output"

	session_dir="$(printf '%s\n' "$output" | capture_field "Session Dir")"
	[ -n "$session_dir" ] || fail "unable to determine vector session directory"
	link="$(track_operation_action_session "$ATLAS_OP_DIR" "$ATLAS_OP_FILE" "$session_dir")"
	atlas_ledger_append_current "tool.completed" "safe-validation" "vector" "ok" "lane=$lane session_dir=$session_dir"
	record_operation_history "$ATLAS_OP_DIR" "action:$lane" "$session_dir"

	printf 'operation_action_session: %s\n' "$session_dir"
	printf 'operation_action_link: %s\n' "$link"
}

