. "$TOOL_DIR/lib/findings.sh"
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/validation.sh
. "$TOOL_DIR/lib/validation.sh"
# shellcheck source-path=SCRIPTDIR
