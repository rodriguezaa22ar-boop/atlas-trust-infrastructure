	run_vector outcomes "$ATLAS_OP_TARGET"
}

fail_legacy_recon_execution() {
	fail "scoped execution required: use 'atlas op recon <workflow>' inside an active operation"
}

menu_prompt() {
	local active_name="none"
	local active_target="none"

	if has_active_operation; then
		load_active_operation
		active_name="$ATLAS_OP_NAME"
		active_target="$ATLAS_OP_TARGET"
	fi

	ui_heading "Atlas Operator Console"
	ui_rule
	ui_kv "Role" "$LAB_ROLE"
	ui_kv "Runtime Target" "$LAB_RUNTIME_TARGET"
	ui_kv "Active Operation" "$active_name"
	ui_kv "Active Target" "$active_target"
	ui_kv "Recon Engine" "$(basename "$WIREMAP_BIN")"
	ui_kv "Action Engine" "$(basename "$VECTOR_BIN")"
	ui_rule
	printf '%s %s\n' "$(ui_dim "[1]")" "operation status"
	printf '%s %s\n' "$(ui_dim "[2]")" "target story"
	printf '%s %s\n' "$(ui_dim "[3]")" "exposure cycle"
	printf '%s %s\n' "$(ui_dim "[4]")" "recon console"
	printf '%s %s\n' "$(ui_dim "[5]")" "action console"
	printf '%s %s\n' "$(ui_dim "[6]")" "intel summary"
	printf '%s %s\n' "$(ui_dim "[7]")" "target list"
	printf '%s %s\n' "$(ui_dim "[8]")" "session list"
	printf '%s %s\n' "$(ui_dim "[0]")" "exit"
	ui_rule
}

menu_action() {
	case "$1" in
	1) printf 'op-status\n' ;;
	2) printf 'target-story\n' ;;
	3) printf 'cycle\n' ;;
	4) printf 'recon-menu\n' ;;
	5) printf 'action-menu\n' ;;
	6) printf 'intel-summary\n' ;;
	7) printf 'target-list\n' ;;
	8) printf 'session-list\n' ;;
	0) printf 'exit\n' ;;
	*) printf 'invalid\n' ;;
	esac
}

cmd_menu() {
	local selection
	local action
	local target

	while true; do
		menu_prompt
		prompt_input selection "choice"
		action="$(menu_action "$selection")"

		case "$action" in
		exit)
			return 0
			;;
		op-status)
			if has_active_operation; then
				cmd_op_status
			else
				ui_note "no active operation; use 'atlas op start' or 'atlas op resume'"
			fi
			return 0
			;;
		target-story)
			prompt_input target "target"
			[ -n "$target" ] || fail "target is required"
			cmd_target_story "$target"
			return 0
			;;
		cycle)
			if has_active_operation; then
				cmd_cycle
			else
				prompt_input target "target"
				[ -n "$target" ] || fail "target is required"
				cmd_cycle_target "$target"
			fi
			return 0
			;;
		recon-menu)
			run_wiremap menu
			return 0
			;;
		action-menu)
			run_vector menu
			return 0
			;;
		intel-summary)
			run_intelctl summary
			return 0
			;;
		target-list)
			run_labctl target list
			return 0
			;;
		session-list)
			run_vector session list
			return 0
			;;
		invalid)
			printf 'invalid choice\n' >&2
			;;
		esac
	done
}

dispatch_validation_command() {
	case "${1:-list}" in
	"" | list)
		[ "$#" -gt 0 ] && shift
		cmd_validation_list "$@"
		;;
	plan)
		shift
		cmd_validation_plan "$@"
		;;
	show)
		shift
		cmd_validation_show "$@"
		;;
	approve)
		shift
		cmd_validation_approve "$@"
		;;
	run)
		shift
		cmd_validation_run "$@"
		;;
	retest)
		shift
		cmd_validation_retest "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
}

case "${1:-help}" in
help | -h | --help)
	usage
	;;
doctor)
	shift
	cmd_doctor "$@"
	;;
profile)
	shift
	case "${1:-list}" in
	"" | list)
		[ "$#" -gt 0 ] && shift
		cmd_profile_list "$@"
		;;
	show)
		shift
		cmd_profile_show "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
scope)
	shift
	case "${1:-status}" in
	"" | status)
		[ "$#" -gt 0 ] && shift
		cmd_scope_status "$@"
		;;
	check)
		shift
		cmd_scope_check "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
approval)
	shift
	case "${1:-list}" in
	"" | list)
		[ "$#" -gt 0 ] && shift
		cmd_approval_list "$@"
		;;
	grant)
		shift
		cmd_approval_grant "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
evidence)
	shift
	case "${1:-list}" in
	"" | list)
		[ "$#" -gt 0 ] && shift
		cmd_evidence_list "$@"
		;;
	add)
		shift
		cmd_evidence_add "$@"
		;;
	redact)
		shift
		cmd_evidence_redact "$@"
		;;
	bundle)
		shift
		cmd_evidence_bundle "$@"
		;;
	show)
		shift
		cmd_evidence_show "$@"
		;;
	hash)
		shift
		cmd_evidence_hash "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
finding | findings)
	shift
	case "${1:-list}" in
	"" | list)
		[ "$#" -gt 0 ] && shift
		cmd_finding_list "$@"
		;;
	add)
		shift
		cmd_finding_add "$@"
		;;
	update)
		shift
		cmd_finding_update "$@"
		;;
	resolve)
		shift
		cmd_finding_resolve "$@"
		;;
	show)
		shift
		cmd_finding_show "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
validation | validations)
	shift
	dispatch_validation_command "$@"
	;;
advisor)
	shift
	case "${1:-brief}" in
	"" | brief)
		[ "$#" -gt 0 ] && shift
		cmd_advisor_brief "$@"
		;;
	prompt)
		shift
		cmd_advisor_prompt "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
menu)
	shift
	cmd_menu "$@"
	;;
op)
	shift
	case "${1:-}" in
	start)
		shift
		cmd_op_start "$@"
		;;
	resume)
		shift
		cmd_op_resume "$@"
		;;
	list)
		shift
		cmd_op_list "$@"
		;;
	show)
		shift
		cmd_op_show "$@"
		;;
	status)
		shift
		cmd_op_status "$@"
		;;
	story)
		shift
		cmd_op_story "$@"
		;;
	cycle)
		shift
		cmd_cycle_operation "$@"
		;;
	report)
		shift
		cmd_op_report "$@"
		;;
	readiness)
		shift
		cmd_op_readiness "$@"
		;;
	next)
		shift
		cmd_op_next "$@"
		;;
	close)
		shift
		cmd_op_close "$@"
		;;
	recon)
		shift
		cmd_op_recon "$@"
		;;
	capture)
		shift
		cmd_op_capture "$@"
		;;
	action)
		shift
		case "${1:-}" in
		candidates)
			shift
			cmd_op_action_candidates "$@"
			;;
		plan)
			shift
			cmd_op_action_plan "$@"
			;;
		run)
			shift
			cmd_op_action_run "$@"
			;;
		outcomes)
			shift
			cmd_op_action_outcomes "$@"
			;;
		*)
			usage
			exit 1
			;;
		esac
		;;
	validation | validations)
		shift
		dispatch_validation_command "$@"
		;;
	brief)
		shift
		cmd_op_brief "$@"
		;;
	advisor)
		shift
		cmd_advisor_brief "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
target)
	shift
	case "${1:-}" in
	add)
		shift
		run_labctl target add "$@"
		;;
	update)
		shift
		run_labctl target update "$@"
		;;
	list)
		shift
		run_labctl target list "$@"
		;;
	show)
		shift
		run_labctl target show "$@"
		;;
	brief)
		shift
		cmd_target_brief "$@"
		;;
	cycle)
		shift
		cmd_cycle_target "$@"
		;;
	story)
		shift
		cmd_target_story "$@"
		;;
	summary)
		shift
		cmd_target_summary "$@"
		;;
	next)
		shift
		cmd_target_next "$@"
		;;
	services | web | lateral)
		run_vector target "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
recon)
	shift
	case "${1:-}" in
	menu)
		shift
		run_wiremap menu "$@"
		;;
	workflow)
		shift
		case "${1:-}" in
		run)
			fail_legacy_recon_execution
			;;
		*)
			run_wiremap workflow "$@"
			;;
		esac
		;;
	run)
		fail_legacy_recon_execution
		;;
	profile | plan | analyze | review | prune | intel)
		run_wiremap "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
capture)
	shift
	case "${1:-}" in
	inspect | streams | creds | anomalies)
		run_wiremap capture "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
action)
	shift
	case "${1:-}" in
	menu | lanes | lane | target)
		run_vector "$@"
		;;
	candidates)
		shift
		cmd_direct_action_candidates "$@"
		;;
	plan)
		shift
		cmd_direct_action_plan "$@"
		;;
	run)
		shift
		cmd_direct_action_run "$@"
		;;
	outcomes)
		shift
		cmd_direct_action_outcomes "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
session)
	shift
	case "${1:-}" in
	list | show)
		run_vector session "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
loot)
	shift
	case "${1:-}" in
	list)
		run_vector loot "$@"
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
story)
	shift
	cmd_target_story "$@"
	;;
cycle)
	shift
	cmd_cycle "$@"
	;;
intel)
	shift
	case "${1:-summary}" in
	"")
		run_intelctl summary
		;;
	summary | observations | entities | outcomes | relationships | graph | paths)
		if [ "$#" -eq 0 ]; then
			run_intelctl summary
		else
			run_intelctl "$@"
		fi
		;;
	*)
		usage
		exit 1
		;;
	esac
	;;
*)
	printf '%s\n' "$TOOL_NAME: unknown subcommand '$1'" >&2
	usage >&2
	exit 1
	;;
esac
