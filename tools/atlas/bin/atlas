ensure_runner() {
	local runner="$1"
	local label="$2"

	[ -x "$runner" ] || fail "missing $label runtime: $runner"
}

run_wiremap() {
	ensure_runner "$WIREMAP_BIN" "wiremap"
	"$WIREMAP_BIN" "$@"
}

run_vector() {
	ensure_runner "$VECTOR_BIN" "vector"
	"$VECTOR_BIN" "$@"
}

run_intelctl() {
	ensure_runner "$INTELCTL_BIN" "intelctl"
	"$INTELCTL_BIN" "$@"
}

run_labctl() {
	ensure_runner "$LABCTL_BIN" "labctl"
	"$LABCTL_BIN" "$@"
}

atlas_scope_text() {
	if [ -n "${ATLAS_SCOPE_TEXT:-}" ]; then
		printf '%s\n' "$ATLAS_SCOPE_TEXT"
	else
		atlas_scope_default_text
	fi
}

atlas_allowed_actions() {
	if ! atlas_scope_print_pipe_lines "${ATLAS_SCOPE_ALLOWED_ACTIONS:-}"; then
		atlas_scope_default_allowed_actions
	fi
}

atlas_out_of_scope() {
	if ! atlas_scope_print_pipe_lines "${ATLAS_SCOPE_OUT_OF_SCOPE_ACTIONS:-}"; then
		atlas_scope_default_out_of_scope
	fi
}

atlas_recommended_workflows() {
	atlas_scope_print_pipe_lines "${ATLAS_SCOPE_RECOMMENDED_WORKFLOWS:-}" || true
}

print_scope_lines() {
	local producer="$1"

	while IFS= read -r line; do
		[ -n "$line" ] || continue
		printf '  %s %s\n' "$(ui_dim "-")" "$line"
	done < <("$producer")
}

prompt_input() {
	local __var="$1"
	local label="$2"
	local value

	printf '%s ' "$(ui_dim "$label:")"
	IFS= read -r value
	printf -v "$__var" '%s' "$value"
}

capture_field() {
	local key="$1"
	awk -F': ' -v wanted="$key" '$1 == wanted { print $2; exit }'
}

session_slug_for() {
	slugify "$1"
}

atlas_op_dir_for_slug() {
	local slug="$1"
	printf '%s/%s\n' "$LAB_SESSIONS_DIR" "$slug"
}

atlas_op_file_for_slug() {
	local slug="$1"
	printf '%s/session.env\n' "$(atlas_op_dir_for_slug "$slug")"
}

resolve_target_input() {
	local input="$1"
	local target_slug
	local target_file
	local NAME=""
	local ADDRESS=""
	local SCOPE_STATUS=""
	local CRITICALITY=""
	local TAGS=""
	local OWNER=""

	target_slug="$(slugify "$input")"
	target_file="$LAB_TARGETS_DIR/$target_slug.env"

	if [ -f "$target_file" ]; then
		# shellcheck disable=SC1090
		. "$target_file"
		ATLAS_TARGET_RESOLVED="${NAME:-$input}"
		ATLAS_TARGET_LABEL="${NAME:-$input}"
		ATLAS_TARGET_ADDRESS="${ADDRESS:-$ATLAS_TARGET_RESOLVED}"
		ATLAS_TARGET_SCOPE_STATUS="${SCOPE_STATUS:-unknown}"
		ATLAS_TARGET_CRITICALITY="${CRITICALITY:-unknown}"
		ATLAS_TARGET_TAGS="${TAGS:-}"
		ATLAS_TARGET_OWNER="${OWNER:-}"
		return 0
	fi

	ATLAS_TARGET_RESOLVED="$input"
	ATLAS_TARGET_LABEL="$input"
	ATLAS_TARGET_ADDRESS="$input"
	ATLAS_TARGET_SCOPE_STATUS="unknown"
	ATLAS_TARGET_CRITICALITY="unknown"
	ATLAS_TARGET_TAGS=""
	ATLAS_TARGET_OWNER=""
}

target_refuse_out_of_scope() {
	if [ "${ATLAS_TARGET_SCOPE_STATUS:-unknown}" = "out-of-scope" ]; then
		fail "target '$ATLAS_TARGET_RESOLVED' is marked out-of-scope in target registry"
	fi
}

print_resolved_target_metadata() {
	ui_kv "Scope Status" "${ATLAS_TARGET_SCOPE_STATUS:-unknown}"
	ui_kv "Criticality" "${ATLAS_TARGET_CRITICALITY:-unknown}"
	if [ -n "${ATLAS_TARGET_OWNER:-}" ]; then
		ui_kv "Owner" "$ATLAS_TARGET_OWNER"
	fi
	if [ -n "${ATLAS_TARGET_TAGS:-}" ]; then
		ui_kv "Tags" "$ATLAS_TARGET_TAGS"
	fi
}

load_atlas_operation_by_slug() {
	local slug="$1"
	local file
	local NAME=""
	local SLUG=""
	local TARGET=""
	local TARGET_ADDRESS=""
	local TARGET_LABEL=""
	local TARGET_SCOPE_STATUS=""
	local TARGET_CRITICALITY=""
	local TARGET_TAGS=""
	local TARGET_OWNER=""
	local STATUS=""
	local CREATED_AT=""
	local CLOSED_AT=""
	local LAST_RESUMED_AT=""
	local LAST_RECON_RUN=""
	local LAST_RECON_AT=""
	local LAST_ACTION_SESSION=""
	local LAST_ACTION_AT=""
	local NOTES=""
	local SOURCE_TOOL=""
	local MODE=""

	file="$(atlas_op_file_for_slug "$slug")"
	[ -f "$file" ] || fail "unknown operation: $slug"

	# shellcheck disable=SC1090
	. "$file"

	[ "${SOURCE_TOOL:-}" = "$TOOL_NAME" ] || fail "not an atlas operation: $slug"
	[ "${MODE:-}" = "operation" ] || fail "invalid atlas operation record: $slug"

	ATLAS_OP_NAME="$NAME"
	ATLAS_OP_SLUG="$SLUG"
	ATLAS_OP_TARGET="$TARGET"
	ATLAS_OP_TARGET_ADDRESS="${TARGET_ADDRESS:-$TARGET}"
	ATLAS_OP_TARGET_LABEL="${TARGET_LABEL:-$TARGET}"
	ATLAS_OP_TARGET_SCOPE_STATUS="${TARGET_SCOPE_STATUS:-unknown}"
	ATLAS_OP_TARGET_CRITICALITY="${TARGET_CRITICALITY:-unknown}"
	ATLAS_OP_TARGET_TAGS="${TARGET_TAGS:-}"
	ATLAS_OP_TARGET_OWNER="${TARGET_OWNER:-}"
	ATLAS_OP_STATUS="$STATUS"
	ATLAS_OP_CREATED_AT="$CREATED_AT"
	ATLAS_OP_CLOSED_AT="${CLOSED_AT:-}"
	ATLAS_OP_LAST_RESUMED_AT="${LAST_RESUMED_AT:-}"
	ATLAS_OP_LAST_RECON_RUN="${LAST_RECON_RUN:-}"
	ATLAS_OP_LAST_RECON_AT="${LAST_RECON_AT:-}"
	ATLAS_OP_LAST_ACTION_SESSION="${LAST_ACTION_SESSION:-}"
	ATLAS_OP_LAST_ACTION_AT="${LAST_ACTION_AT:-}"
	ATLAS_OP_NOTES="${NOTES:-}"
	ATLAS_OP_DIR="$(dirname "$file")"
	ATLAS_OP_FILE="$file"
}

load_atlas_operation() {
	local slug
	slug="$(session_slug_for "$1")"
	load_atlas_operation_by_slug "$slug"
}

set_active_operation() {
	local slug="$1"

	: >"$ATLAS_ACTIVE_OP_FILE"
	upsert_env "$ATLAS_ACTIVE_OP_FILE" ACTIVE_OPERATION "$slug"
	upsert_env "$ATLAS_ACTIVE_OP_FILE" SET_AT "$(timestamp)"
}

clear_active_operation() {
	rm -f "$ATLAS_ACTIVE_OP_FILE"
}

active_operation_slug() {
	local ACTIVE_OPERATION=""

	[ -f "$ATLAS_ACTIVE_OP_FILE" ] || return 1
	# shellcheck disable=SC1090
	. "$ATLAS_ACTIVE_OP_FILE"
	[ -n "${ACTIVE_OPERATION:-}" ] || return 1
	[ -f "$(atlas_op_file_for_slug "$ACTIVE_OPERATION")" ] || return 1

	printf '%s\n' "$ACTIVE_OPERATION"
}

has_active_operation() {
	active_operation_slug >/dev/null 2>&1
}

load_active_operation() {
	local slug

	slug="$(active_operation_slug)" || fail "no active operation; use 'atlas op start' or 'atlas op resume'"
	load_atlas_operation_by_slug "$slug"
}

operation_is_active() {
	local slug="$1"
	local active_slug

	active_slug="$(active_operation_slug 2>/dev/null || true)"
	[ -n "$active_slug" ] && [ "$active_slug" = "$slug" ]
}

list_atlas_operation_files() {
	local file
	local SOURCE_TOOL=""
	local MODE=""

	for file in "$LAB_SESSIONS_DIR"/*/session.env; do
		[ -e "$file" ] || return 0
		SOURCE_TOOL=""
		MODE=""
		# shellcheck disable=SC1090
		. "$file"
		if [ "${SOURCE_TOOL:-}" = "$TOOL_NAME" ] && [ "${MODE:-}" = "operation" ]; then
			printf '%s\n' "$file"
		fi
	done
}

operation_count_entries() {
	local dir="$1"

	if [ ! -d "$dir" ]; then
		printf '0'
		return 0
	fi

	find "$dir" -mindepth 1 -maxdepth 1 | wc -l | tr -d ' '
}

operation_latest_entry() {
	local dir="$1"
	local entries=()
	local path

	if [ ! -d "$dir" ]; then
		return 0
	fi

	while IFS= read -r path; do
		entries+=("$path")
	done < <(find "$dir" -mindepth 1 -maxdepth 1 | sort)

	[ "${#entries[@]}" -gt 0 ] || return 0
	printf '%s\n' "${entries[$((${#entries[@]} - 1))]}"
}

print_operation_entries() {
	local dir="$1"
	local empty_note="$2"
	local path
	local count=0

	if [ ! -d "$dir" ]; then
		ui_note "$empty_note"
		return 0
	fi

	for path in "$dir"/*; do
		[ -e "$path" ] || continue
		printf '  %s %s\n' "$(ui_dim "-")" "$(basename "$path")"
		count=$((count + 1))
	done

	if [ "$count" -eq 0 ]; then
		ui_note "$empty_note"
	fi
}

record_operation_history() {
	local dir="$1"
	local event="$2"
	local detail="$3"

	printf '%s\t%s\t%s\n' "$(timestamp)" "$event" "$detail" >>"$dir/notes/history.log"
}

track_operation_recon_run() {
	local dir="$1"
	local file="$2"
	local run_dir="$3"
	local link

	link="$dir/recon-runs/$(basename "$run_dir")"
	ln -sfn "$run_dir" "$link"
	upsert_env "$file" LAST_RECON_RUN "$run_dir"
	upsert_env "$file" LAST_RECON_AT "$(timestamp)"

	printf '%s\n' "$link"
}

track_operation_action_session() {
	local dir="$1"
	local file="$2"
	local session_dir="$3"
	local link

	link="$dir/action-sessions/$(basename "$session_dir")"
	ln -sfn "$session_dir" "$link"
	upsert_env "$file" LAST_ACTION_SESSION "$session_dir"
	upsert_env "$file" LAST_ACTION_AT "$(timestamp)"

	printf '%s\n' "$link"
}

latest_operation_recon_run() {
	if [ -n "$ATLAS_OP_LAST_RECON_RUN" ] && [ -e "$ATLAS_OP_LAST_RECON_RUN" ]; then
		printf '%s\n' "$ATLAS_OP_LAST_RECON_RUN"
		return 0
	fi

	operation_latest_entry "$ATLAS_OP_DIR/recon-runs" | xargs -r readlink -f
}

format_operation_target() {
	local rendered

	if [ "$ATLAS_OP_TARGET_LABEL" = "$ATLAS_OP_TARGET" ]; then
		rendered="$ATLAS_OP_TARGET"
	else
		rendered="$ATLAS_OP_TARGET ($ATLAS_OP_TARGET_LABEL)"
	fi

	if [ -n "${ATLAS_OP_TARGET_ADDRESS:-}" ] && [ "$ATLAS_OP_TARGET_ADDRESS" != "$ATLAS_OP_TARGET" ]; then
		printf '%s -> %s\n' "$rendered" "$ATLAS_OP_TARGET_ADDRESS"
	else
		printf '%s\n' "$rendered"
	fi
}

print_operation_summary() {
	local active_flag="no"
	local latest_recon=""
	local latest_action=""

	atlas_scope_load_snapshot

	if operation_is_active "$ATLAS_OP_SLUG"; then
		active_flag="yes"
	fi

	latest_recon="${ATLAS_OP_LAST_RECON_RUN:-}"
	if [ -z "$latest_recon" ]; then
		latest_recon="$(latest_operation_recon_run)"
	fi
	latest_action="${ATLAS_OP_LAST_ACTION_SESSION:-}"
	if [ -z "$latest_action" ]; then
		latest_action="$(operation_latest_entry "$ATLAS_OP_DIR/action-sessions" | xargs -r readlink -f)"
	fi

	ui_kv "Operation" "$ATLAS_OP_NAME"
	ui_kv "Target" "$(format_operation_target)"
	ui_kv "Target Scope" "${ATLAS_OP_TARGET_SCOPE_STATUS:-unknown}"
	ui_kv "Target Criticality" "${ATLAS_OP_TARGET_CRITICALITY:-unknown}"
	if [ -n "${ATLAS_OP_TARGET_OWNER:-}" ]; then
		ui_kv "Target Owner" "$ATLAS_OP_TARGET_OWNER"
	fi
	if [ -n "${ATLAS_OP_TARGET_TAGS:-}" ]; then
		ui_kv "Target Tags" "$ATLAS_OP_TARGET_TAGS"
	fi
	ui_kv "Status" "$ATLAS_OP_STATUS"
	ui_kv "Profile" "$ATLAS_SCOPE_PROFILE"
	ui_kv "Active" "$active_flag"
	ui_kv "Created" "$ATLAS_OP_CREATED_AT"
	if [ -n "$ATLAS_OP_CLOSED_AT" ]; then
		ui_kv "Closed" "$ATLAS_OP_CLOSED_AT"
	fi
	if [ -n "$ATLAS_OP_LAST_RESUMED_AT" ]; then
		ui_kv "Resumed" "$ATLAS_OP_LAST_RESUMED_AT"
	fi
	if [ -n "$ATLAS_OP_LAST_RECON_AT" ]; then
		ui_kv "Last Recon At" "$ATLAS_OP_LAST_RECON_AT"
	fi
	if [ -n "$ATLAS_OP_LAST_ACTION_AT" ]; then
		ui_kv "Last Action At" "$ATLAS_OP_LAST_ACTION_AT"
	fi
	if [ -n "$ATLAS_OP_NOTES" ]; then
		ui_kv "Notes" "$ATLAS_OP_NOTES"
	fi
	ui_kv "Recon Runs" "$(operation_count_entries "$ATLAS_OP_DIR/recon-runs")"
	ui_kv "Action Sessions" "$(operation_count_entries "$ATLAS_OP_DIR/action-sessions")"
	ui_kv "Evidence" "$(atlas_evidence_count_for_target "$ATLAS_OP_TARGET")"
	ui_kv "Findings" "$(atlas_findings_count_for_target "$ATLAS_OP_TARGET")"
	ui_kv "Validation Plans" "$(atlas_validation_count_for_target "$ATLAS_OP_TARGET")"
	ui_kv "Dir" "$ATLAS_OP_DIR"
	ui_kv "Latest Recon" "${latest_recon:-none}"
	ui_kv "Latest Action" "${latest_action:-none}"
}

operation_target_matches_identifier() {
	local target="$1"

	[ "$target" = "$ATLAS_OP_TARGET" ] && return 0
	[ -n "${ATLAS_OP_TARGET_ADDRESS:-}" ] && [ "$target" = "$ATLAS_OP_TARGET_ADDRESS" ] && return 0
	[ -n "${ATLAS_OP_TARGET_LABEL:-}" ] && [ "$target" = "$ATLAS_OP_TARGET_LABEL" ] && return 0
	return 1
}

print_operation_evidence_summary() {
	local target="${1:-$ATLAS_OP_TARGET}"
	local limit="${2:-8}"

	atlas_evidence_print_table_for_target "$target" "$limit" "no operation evidence recorded yet"
}

print_operation_findings_summary() {
	local target="${1:-$ATLAS_OP_TARGET}"
	local limit="${2:-8}"

	atlas_findings_print_table_for_target "$target" "$limit" "no operation findings recorded yet"
}

print_active_operation_records_for_target() {
	local target="$1"

	[ "${ATLAS_SUPPRESS_ACTIVE_OP_CONTEXT:-0}" = "1" ] && return 0
	has_active_operation || return 0
	load_active_operation
	operation_target_matches_identifier "$target" || return 0

	ui_subheading "Active Operation Evidence"
	print_operation_evidence_summary "$ATLAS_OP_TARGET" 8
	ui_rule

	ui_subheading "Active Operation Findings"
	print_operation_findings_summary "$ATLAS_OP_TARGET" 8
	ui_rule

	ui_subheading "Active Validation Plans"
	atlas_validation_print_table_for_target "$ATLAS_OP_TARGET" 8 "no operation validation plans recorded yet"
	ui_rule
}

cmd_target_summary() {
	need_args 1 "$#" "target summary <target>"
	local target="$1"

	run_vector target summary "$target"
	printf '\n'
	run_vector candidates "$target"
}

cmd_target_brief() {
	need_args 1 "$#" "target brief <target>"
	local target_input="$1"
	local target

	resolve_target_input "$target_input"
	target="$ATLAS_TARGET_RESOLVED"

	ui_heading "Operator Brief"
	ui_rule
	ui_kv "Target" "$target"
	if [ "$ATLAS_TARGET_ADDRESS" != "$target" ]; then
		ui_kv "Address" "$ATLAS_TARGET_ADDRESS"
	fi
	print_resolved_target_metadata
	ui_rule
	atlas_brief_print_target "$target"
}

print_tool_output_or_note() {
	local empty_note="$1"
	shift
	local output

	if output="$("$@" 2>/dev/null)" && [ -n "$output" ]; then
		printf '%s\n' "$output"
	else
		ui_note "$empty_note"
	fi
}

story_observation_rows() {
	local target="$1"
	local observation_type="${2:-}"
	local limit="${3:-12}"
	local latest_only="0"

	if [[ "$observation_type" == latest:* ]]; then
		latest_only="1"
		observation_type="${observation_type#latest:}"
	fi

	intel_ensure_store
	intel_require_jq

	jq -sr \
		--arg target "$target" \
		--arg observation_type "$observation_type" \
		--arg latest_only "$latest_only" \
		--argjson limit "$limit" '
    def clean: tostring | gsub("[\r\n\t]+"; " ") | gsub("^ +| +$"; "");
    def story_evidence_types:
      [
        "host_state",
        "service_open",
        "service_validation",
        "web_surface",
        "web_probe",
        "credential_surface",
        "credential_hint",
        "capture_anomaly",
        "lateral_surface"
      ];
    def service_detail:
      ((.value.portproto // "?") + " " + (.value.service // "?") +
      (if (.value.detail // "") != "" then " " + (.value.detail | clean) else "" end));
    def observation_detail:
      if .observation_type == "service_open" then
        service_detail
      elif .observation_type == "web_surface" then
        (.value.endpoint // (.value.portproto // "?"))
      elif .observation_type == "web_probe" then
        (.value.endpoint // "?") + " status=" + (.value.status_code // "?") +
        (if (.value.server // "") != "" then " server=" + (.value.server | clean) else "" end) +
        (if (.value.title // "") != "" then " title=" + (.value.title | clean) else "" end)
      elif .observation_type == "http_posture" then
        (.value.url // "?") + " status=" + (.value.status_code // "?") +
        (if (.value.location // "") != "" then " location=" + (.value.location | clean) else "" end)
      elif .observation_type == "http_posture_finding" then
        (.value.severity // "?") + " " + (.value.label // "finding") + " " + (.value.url // "?") +
        (if (.value.detail // "") != "" then " " + (.value.detail | clean) else "" end)
      elif .observation_type == "lateral_surface" then
        (.value.label // "surface") + " " + service_detail
      elif .observation_type == "host_state" then
        (.value.state // "unknown")
      elif .observation_type == "credential_hint" or .observation_type == "capture_anomaly" then
        (.value.label // "signal") + (if (.value.evidence // "") != "" then " " + (.value.evidence | clean) else "" end)
      elif .observation_type == "service_validation" or .observation_type == "credential_surface" then
        service_detail
      elif .observation_type == "module_candidate" then
        (.value.portproto // "?") + " " + (.value.module_name // "?") + " [" + (.value.module_source // "?") + "] " +
        (.value.rationale // "")
      else
        (.source_name // "?")
      end;
    map(select(
      .target == $target
      and (
        if $observation_type == "__story_evidence" then
          ((.observation_type // "") as $type | story_evidence_types | index($type))
        else
          ($observation_type == "" or .observation_type == $observation_type)
        end
      )
    ))
    | sort_by(.observed_at)
    | if $latest_only == "1" and length > 0 then
        (.[-1].source_run_id // "") as $latest_run
        | map(select((.source_run_id // "") == $latest_run))
      else
        .
      end
    | sort_by(.observed_at)
    | reverse
    | .[:$limit]
    | .[]
    | [
        (.observed_at // "?"),
        (.observation_type // "?"),
        (.confidence // "?"),
        (.source_tool // "?"),
        observation_detail
      ]
    | @tsv
  ' "$LAB_INTEL_OBSERVATIONS_FILE"
}

print_story_observations() {
	local target="$1"
	local observation_type="$2"
	local empty_note="$3"
	local limit="${4:-12}"
	local output

	output="$(
		story_observation_rows "$target" "$observation_type" "$limit" |
			awk -F'\t' '{ printf "%-20s %-22s %-8s %-10s %s\n", $1, $2, $3, $4, $5 }'
	)"
	if [ -n "$output" ]; then
		printf '%s\n' "$output"
	else
		ui_note "$empty_note"
	fi
}

print_story_recent_evidence() {
	local target="$1"
	local limit="${2:-12}"
	local output

	output="$(
		story_observation_rows "$target" "__story_evidence" 200 |
			awk -F'\t' -v limit="$limit" '
        !seen[$2 SUBSEP $5] {
          seen[$2 SUBSEP $5] = 1
          printf "%-20s %-22s %-8s %-10s %s\n", $1, $2, $3, $4, $5
          count++
          if (count >= limit) {
            exit
          }
        }
      '
	)"

	if [ -n "$output" ]; then
		printf '%s\n' "$output"
	else
		ui_note "no recent cross-tool evidence recorded yet"
	fi
}

cmd_target_story() {
	need_args 1 "$#" "target story <target>"
	local target_input="$1"
	local target

	if [ "$target_input" = "demo-web-app" ]; then
		cmd_demo_story
		return 0
	fi

	resolve_target_input "$target_input"
	target="$ATLAS_TARGET_RESOLVED"

	ui_heading "Target Story"
	ui_rule
	ui_kv "Target" "$target"
	if [ "$ATLAS_TARGET_ADDRESS" != "$target" ]; then
		ui_kv "Address" "$ATLAS_TARGET_ADDRESS"
	fi
	print_resolved_target_metadata
	ui_kv "Shared Intel" "$LAB_INTEL_DIR"
	ui_rule

	ui_subheading "Operator Brief"
	atlas_brief_print_target "$target"
	ui_rule

	ui_subheading "Target Record"
	print_tool_output_or_note "no target record found; add one with atlas target add <name> <address>" run_labctl target show "$target"
	ui_rule

	ui_subheading "Current Surface"
	print_tool_output_or_note "no surface summary available; run atlas op recon <workflow> first" run_vector target summary "$target"
	ui_rule

	ui_subheading "Web Surface"
	print_tool_output_or_note "no web surface recorded yet" run_vector target web "$target"
	ui_rule

	ui_subheading "Action Outcomes"
	print_tool_output_or_note "no Vector outcomes recorded yet" run_vector outcomes "$target"
	ui_rule

	ui_subheading "Posture Findings"
	print_story_observations "$target" "latest:http_posture_finding" "no HTTP posture findings recorded yet" 12
	ui_rule

	print_active_operation_records_for_target "$target"

	ui_subheading "Recent Evidence"
	print_story_recent_evidence "$target" 12
	ui_rule

	ui_subheading "Next Actions"
	print_tool_output_or_note "no candidate lanes produced from current intel" run_vector candidates "$target"
	ui_rule
	ui_note "research module candidates are omitted here; use 'atlas intel observations $target module_candidate' for raw module detail"
}

cmd_target_next() {
	need_args 1 "$#" "target next <target>"
	run_vector candidates "$1"
}

