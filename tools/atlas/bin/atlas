	need_args 1 "$#" "action candidates <target>"
	local target="$1"

	load_active_operation
	atlas_scope_preflight "read-only" "vector" "$target" "list action candidates through legacy route"
	run_vector candidates "$ATLAS_OP_TARGET"
}

cmd_direct_action_plan() {
	need_args 2 "$#" "action plan <lane> <target>"
	local lane="$1"
	local target="$2"

	load_active_operation
	atlas_scope_preflight "read-only" "vector" "$target" "plan action lane $lane through legacy route"
	run_vector plan "$lane" "$ATLAS_OP_TARGET"
}

cmd_direct_action_run() {
	need_args 2 "$#" "action run <lane> <target> [session-name]"
	local lane="$1"
	local target="$2"
	local session_name="${3:-}"
	local output
	local session_dir
	local link

	load_active_operation
	atlas_scope_preflight "safe-validation" "vector" "$target" "run action lane $lane through legacy route"

	if [ -z "$session_name" ]; then
		session_name="$ATLAS_OP_NAME $lane"
	fi

	output="$(run_vector run "$lane" "$ATLAS_OP_TARGET" "$session_name")"
	printf '%s\n' "$output"

	session_dir="$(printf '%s\n' "$output" | capture_field "Session Dir")"
	[ -n "$session_dir" ] || fail "unable to determine vector session directory"
	link="$(track_operation_action_session "$ATLAS_OP_DIR" "$ATLAS_OP_FILE" "$session_dir")"
	atlas_ledger_append_current "tool.completed" "safe-validation" "vector" "ok" "legacy-route lane=$lane session_dir=$session_dir"
	record_operation_history "$ATLAS_OP_DIR" "action:$lane" "$session_dir"

	printf 'operation_action_session: %s\n' "$session_dir"
	printf 'operation_action_link: %s\n' "$link"
}

