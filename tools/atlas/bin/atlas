cmd_op_start() {
	local profile="default"
	local name
	local target_input
	local notes
	local slug
	local dir
	local file

	while [ "$#" -gt 0 ]; do
		case "$1" in
		--profile)
			need_args 2 "$#" "op start --profile <profile> <name> <target> [notes...]"
			profile="$2"
			shift 2
			;;
		--)
			shift
			break
			;;
		*)
			break
			;;
		esac
	done

	need_args 2 "$#" "op start [--profile profile] <name> <target> [notes...]"
	name="$1"
	target_input="$2"
	shift 2
	notes="${*:-}"
	resolve_target_input "$target_input"
	target_refuse_out_of_scope
	atlas_scope_load_profile "$profile"

	slug="$(session_slug_for "$name")"
	[ -n "$slug" ] || fail "operation name produced an empty slug"
	dir="$(atlas_op_dir_for_slug "$slug")"
	file="$dir/session.env"

	[ ! -d "$dir" ] || fail "operation already exists: $slug"

	mkdir -p "$dir/loot" "$dir/pcaps" "$dir/notes" "$dir/logs" "$dir/tmp" "$dir/recon-runs" "$dir/action-sessions" "$dir/evidence" "$dir/findings" "$dir/validation-plans"
	chmod 700 "$dir" "$dir/loot" "$dir/pcaps" "$dir/notes" "$dir/logs" "$dir/tmp" "$dir/recon-runs" "$dir/action-sessions" "$dir/evidence" "$dir/findings" "$dir/validation-plans" 2>/dev/null || true
	: >"$file"
	chmod 600 "$file" 2>/dev/null || true
	upsert_env "$file" NAME "$name"
	upsert_env "$file" SLUG "$slug"
	upsert_env "$file" TARGET "$ATLAS_TARGET_RESOLVED"
	upsert_env "$file" TARGET_ADDRESS "$ATLAS_TARGET_ADDRESS"
	upsert_env "$file" TARGET_LABEL "$ATLAS_TARGET_LABEL"
	upsert_env "$file" TARGET_SCOPE_STATUS "$ATLAS_TARGET_SCOPE_STATUS"
	upsert_env "$file" TARGET_CRITICALITY "$ATLAS_TARGET_CRITICALITY"
	upsert_env "$file" TARGET_TAGS "$ATLAS_TARGET_TAGS"
	upsert_env "$file" TARGET_OWNER "$ATLAS_TARGET_OWNER"
	upsert_env "$file" STATUS "active"
	upsert_env "$file" CREATED_AT "$(timestamp)"
	upsert_env "$file" LAST_RESUMED_AT "$(timestamp)"
	upsert_env "$file" NOTES "$notes"
	upsert_env "$file" SOURCE_TOOL "$TOOL_NAME"
	upsert_env "$file" MODE "operation"

	atlas_scope_write_snapshot "$dir" "$ATLAS_TARGET_RESOLVED" "$ATLAS_TARGET_ADDRESS" "$ATLAS_TARGET_LABEL" "$profile" "$ATLAS_TARGET_SCOPE_STATUS" "$ATLAS_TARGET_CRITICALITY" "$ATLAS_TARGET_TAGS" "$ATLAS_TARGET_OWNER"
	atlas_ledger_append "$dir" "op.started" "$slug" "$ATLAS_TARGET_RESOLVED" "read-only" "atlas" "ok" "profile=$ATLAS_PROFILE_NAME notes=$notes"
	record_operation_history "$dir" "start" "$ATLAS_TARGET_RESOLVED"
	set_active_operation "$slug"

	ui_ok "operation ready"
	printf 'operation: %s\n' "$name"
	printf 'profile: %s\n' "$ATLAS_PROFILE_NAME"
	printf 'target: %s\n' "$ATLAS_TARGET_RESOLVED"
	if [ "$ATLAS_TARGET_ADDRESS" != "$ATLAS_TARGET_RESOLVED" ]; then
		printf 'address: %s\n' "$ATLAS_TARGET_ADDRESS"
	fi
	printf 'scope_status: %s\n' "$ATLAS_TARGET_SCOPE_STATUS"
	printf 'criticality: %s\n' "$ATLAS_TARGET_CRITICALITY"
	if [ -n "$ATLAS_TARGET_TAGS" ]; then
		printf 'tags: %s\n' "$ATLAS_TARGET_TAGS"
	fi
	if [ -n "$ATLAS_TARGET_OWNER" ]; then
		printf 'owner: %s\n' "$ATLAS_TARGET_OWNER"
	fi
	printf 'op_dir: %s\n' "$dir"
	printf 'active_operation: %s\n' "$slug"
}

cmd_op_resume() {
	need_args 1 "$#" "op resume <name>"

	load_atlas_operation "$1"
	upsert_env "$ATLAS_OP_FILE" STATUS "active"
	upsert_env "$ATLAS_OP_FILE" LAST_RESUMED_AT "$(timestamp)"
	upsert_env "$ATLAS_OP_FILE" CLOSED_AT ""
	set_active_operation "$ATLAS_OP_SLUG"
	atlas_ledger_append_current "op.resumed" "read-only" "atlas" "ok" "$ATLAS_OP_TARGET"
	record_operation_history "$ATLAS_OP_DIR" "resume" "$ATLAS_OP_TARGET"

	ui_ok "operation active"
	printf 'operation: %s\n' "$ATLAS_OP_NAME"
	printf 'target: %s\n' "$ATLAS_OP_TARGET"
	if [ "$ATLAS_OP_TARGET_ADDRESS" != "$ATLAS_OP_TARGET" ]; then
		printf 'address: %s\n' "$ATLAS_OP_TARGET_ADDRESS"
	fi
	printf 'active_operation: %s\n' "$ATLAS_OP_SLUG"
}

cmd_op_list() {
	local file
	local NAME=""
	local TARGET=""
	local TARGET_LABEL=""
	local STATUS=""
	local SLUG=""
	local active="no"
	local count=0

	printf '%-24s %-16s %-24s %s\n' "OPERATION" "STATUS" "TARGET" "ACTIVE"
	while IFS= read -r file; do
		NAME=""
		TARGET=""
		TARGET_LABEL=""
		STATUS=""
		SLUG=""
		# shellcheck disable=SC1090
		. "$file"
		active="no"
		if operation_is_active "$SLUG"; then
			active="yes"
		fi
		if [ -n "${TARGET_LABEL:-}" ] && [ "$TARGET_LABEL" != "$TARGET" ]; then
			printf '%-24s %-16s %-24s %s\n' "$NAME" "$STATUS" "$TARGET_LABEL" "$active"
		else
			printf '%-24s %-16s %-24s %s\n' "$NAME" "$STATUS" "$TARGET" "$active"
		fi
		count=$((count + 1))
	done < <(list_atlas_operation_files)

	if [ "$count" -eq 0 ]; then
		ui_note "no atlas operations recorded yet"
	fi
}

cmd_op_status() {
	if [ "$#" -gt 0 ]; then
		load_atlas_operation "$1"
	else
		load_active_operation
	fi

	ui_heading "Operation Status"
	ui_rule
	print_operation_summary
	ui_rule
	ui_subheading "Tracked Recon Runs"
	print_operation_entries "$ATLAS_OP_DIR/recon-runs" "no recon runs tracked yet"
	ui_rule
	ui_subheading "Tracked Action Sessions"
	print_operation_entries "$ATLAS_OP_DIR/action-sessions" "no action sessions tracked yet"
	printf '\n'
	ui_subheading "Operation Evidence"
	print_operation_evidence_summary "$ATLAS_OP_TARGET" 8
	printf '\n'
	ui_subheading "Operation Findings"
	print_operation_findings_summary "$ATLAS_OP_TARGET" 8
	printf '\n'
	ui_subheading "Validation Plans"
	atlas_validation_print_table_for_target "$ATLAS_OP_TARGET" 8 "no operation validation plans recorded yet"
}

