}

print_markdown_list_from_function() {
	local producer="$1"

	while IFS= read -r line; do
		[ -n "$line" ] || continue
		printf -- '- %s\n' "$line"
	done < <("$producer")
}

print_operation_report_commands() {
	local history_file="$ATLAS_OP_DIR/notes/history.log"
	local event
	local detail
	local lane
	local session_name

	if [ ! -s "$history_file" ]; then
		printf -- "- \`%s\`\n" "atlas op start $ATLAS_OP_SLUG $ATLAS_OP_TARGET"
		return 0
	fi

	while IFS=$'\t' read -r _ts event detail; do
		[ -n "$event" ] || continue
		case "$event" in
		start)
			if [ -n "$ATLAS_OP_NOTES" ]; then
				printf -- "- \`%s\`\n" "atlas op start $ATLAS_OP_SLUG $ATLAS_OP_TARGET $ATLAS_OP_NOTES"
			else
				printf -- "- \`%s\`\n" "atlas op start $ATLAS_OP_SLUG $ATLAS_OP_TARGET"
			fi
			;;
		resume)
			printf -- "- \`%s\`\n" "atlas op resume $ATLAS_OP_SLUG"
			;;
		recon:*)
			printf -- "- \`%s\`\n" "atlas op recon ${event#recon:}"
			;;
		capture:*)
			printf -- "- \`%s\`\n" "atlas op capture ${event#capture:} latest"
			;;
		action:*)
			lane="${event#action:}"
			session_name="$(basename "$detail")"
			printf -- "- \`%s\`\n" "atlas op action run $lane $session_name"
			;;
		advisor-prompt)
			printf -- "- \`%s\`\n" "atlas advisor prompt $ATLAS_OP_SLUG $(basename "$detail" .md)"
			;;
		close)
			printf -- "- \`%s\`\n" "atlas op close $ATLAS_OP_SLUG"
			;;
		*)
			printf -- "- \`%s\`\n" "atlas op $event"
			;;
		esac
	done <"$history_file"
}

print_operation_report_artifacts() {
	local path
	local resolved
	local count=0

	printf -- "- Operation directory: \`%s\`\n" "$ATLAS_OP_DIR"
	count=$((count + 1))

	if [ -d "$ATLAS_OP_DIR/recon-runs" ]; then
		for path in "$ATLAS_OP_DIR"/recon-runs/*; do
			[ -e "$path" ] || continue
			resolved="$(readlink -f "$path" 2>/dev/null || printf '%s' "$path")"
			printf -- "- Recon run: \`%s\`\n" "$resolved"
			count=$((count + 1))
		done
	fi

	if [ -d "$ATLAS_OP_DIR/action-sessions" ]; then
		for path in "$ATLAS_OP_DIR"/action-sessions/*; do
			[ -e "$path" ] || continue
			resolved="$(readlink -f "$path" 2>/dev/null || printf '%s' "$path")"
			printf -- "- Action session: \`%s\`\n" "$resolved"
			count=$((count + 1))
		done
	fi

	if [ "$count" -eq 1 ]; then
		printf -- '- No recon or action artifacts tracked yet.\n'
	fi
}

write_operation_report() {
	local file="$1"

	atlas_scope_load_snapshot

	{
		printf '# Atlas Operation Report\n\n'
		printf 'Generated: %s\n' "$(timestamp)"
		printf 'Operation: %s\n' "$ATLAS_OP_NAME"
		printf 'Operation ID: %s\n' "$ATLAS_OP_SLUG"
		printf 'Target: %s\n' "$ATLAS_OP_TARGET"
		if [ -n "${ATLAS_OP_TARGET_ADDRESS:-}" ] && [ "$ATLAS_OP_TARGET_ADDRESS" != "$ATLAS_OP_TARGET" ]; then
			printf 'Address: %s\n' "$ATLAS_OP_TARGET_ADDRESS"
		fi
		printf 'Target Scope Status: %s\n' "${ATLAS_OP_TARGET_SCOPE_STATUS:-unknown}"
		printf 'Target Criticality: %s\n' "${ATLAS_OP_TARGET_CRITICALITY:-unknown}"
		if [ -n "${ATLAS_OP_TARGET_OWNER:-}" ]; then
			printf 'Target Owner: %s\n' "$ATLAS_OP_TARGET_OWNER"
		fi
		if [ -n "${ATLAS_OP_TARGET_TAGS:-}" ]; then
			printf 'Target Tags: %s\n' "$ATLAS_OP_TARGET_TAGS"
		fi
		printf 'Status: %s\n' "$ATLAS_OP_STATUS"
		printf 'Created: %s\n' "$ATLAS_OP_CREATED_AT"
		if [ -n "$ATLAS_OP_CLOSED_AT" ]; then
			printf 'Closed: %s\n' "$ATLAS_OP_CLOSED_AT"
		fi
		if [ -n "$ATLAS_OP_NOTES" ]; then
			printf 'Notes: %s\n' "$ATLAS_OP_NOTES"
		fi
		printf '\n## Executive Summary\n\n'
		atlas_report_executive_summary
		printf '\n## Operator Brief\n\n'
		atlas_brief_report_markdown "$ATLAS_OP_TARGET"
		printf '\n## Finding Review\n\n'
		atlas_report_finding_review
		printf '\n## Remediation Priorities\n\n'
		atlas_report_remediation_priorities
		printf '\n## Scope\n\n'
		printf '%s\n\n' "$(atlas_scope_text)"
		printf '## Allowed Actions\n\n'
		print_markdown_list_from_function atlas_allowed_actions
		printf '\n## Explicitly Out Of Scope\n\n'
		print_markdown_list_from_function atlas_out_of_scope
		printf '\n## Commands Run\n\n'
		print_operation_report_commands
		printf '\n## Artifacts\n\n'
		print_operation_report_artifacts
		printf '\n## Validation Plans\n\n'
		atlas_validation_report_markdown
		printf '\n## Notes\n\n'
		printf -- '- Add operator notes here.\n'
	} >"$file"
}

cmd_op_report() {
	local report_name="${2:-}"
	local report_slug
	local report_file

	if [ "$#" -gt 0 ]; then
		load_atlas_operation "$1"
	else
		load_active_operation
	fi

	if [ -z "$report_name" ]; then
		report_name="$ATLAS_OP_SLUG-report"
	fi
	report_slug="$(slugify "$report_name")"
	[ -n "$report_slug" ] || fail "report name produced an empty slug"
	report_file="$LAB_REPORTS_DIR/$report_slug.md"
	mkdir -p "$LAB_REPORTS_DIR"
	write_operation_report "$report_file"
	atlas_ledger_append_current "report.generated" "read-only" "atlas" "ok" "$report_file"

	ui_ok "operation report written"
	printf 'report: %s\n' "$report_file"
}

cmd_op_readiness() {
	if [ "$#" -gt 0 ]; then
		load_atlas_operation "$1"
	else
		load_active_operation
	fi

	atlas_readiness_print
}

cmd_op_close() {
	local operation_name=""
	local force=0
	local readiness_detail

	while [ "$#" -gt 0 ]; do
		case "$1" in
		--force)
			force=1
			shift
			;;
		-*)
			fail "unknown op close option: $1"
			;;
		*)
			[ -z "$operation_name" ] || fail "unexpected op close argument: $1"
			operation_name="$1"
			shift
			;;
		esac
	done

	if [ -n "$operation_name" ]; then
		load_atlas_operation "$operation_name"
	else
		load_active_operation
	fi

	atlas_readiness_collect "$ATLAS_OP_TARGET"
	readiness_detail="$(atlas_readiness_ledger_detail "$force")"
	if [ "$ATLAS_READINESS_STATUS" != "ready" ] && [ "$force" -ne 1 ]; then
		atlas_readiness_print
		fail "operation is not ready to close; address readiness items or rerun with --force"
	fi

	upsert_env "$ATLAS_OP_FILE" STATUS "closed"
	upsert_env "$ATLAS_OP_FILE" CLOSED_AT "$(timestamp)"
	atlas_ledger_append_current "op.close.readiness" "read-only" "atlas" "$ATLAS_READINESS_STATUS" "$readiness_detail"
	atlas_ledger_append_current "op.closed" "read-only" "atlas" "ok" "$ATLAS_OP_TARGET $readiness_detail"
	record_operation_history "$ATLAS_OP_DIR" "close" "$ATLAS_OP_TARGET"

	if operation_is_active "$ATLAS_OP_SLUG"; then
		clear_active_operation
	fi

	ui_ok "operation closed"
	printf 'operation: %s\n' "$ATLAS_OP_NAME"
	printf 'status: closed\n'
	printf 'readiness: %s\n' "$ATLAS_READINESS_STATUS"
	printf 'force: %s\n' "$force"
}

cmd_op_recon() {
	need_args 1 "$#" "op recon <workflow> [interface]"
	local workflow="$1"
	local iface="${2:-}"
	local output
	local run_dir
	local link

	load_active_operation
	atlas_scope_preflight "active-recon" "wiremap" "$ATLAS_OP_TARGET" "run recon workflow $workflow"

	if [ -n "$iface" ]; then
		output="$(run_wiremap workflow run "$workflow" "$ATLAS_OP_TARGET" "$iface")"
	else
		output="$(run_wiremap workflow run "$workflow" "$ATLAS_OP_TARGET")"
	fi
	printf '%s\n' "$output"

	run_dir="$(printf '%s\n' "$output" | capture_field "workflow_run_dir")"
	[ -n "$run_dir" ] || fail "unable to determine workflow run directory"
	link="$(track_operation_recon_run "$ATLAS_OP_DIR" "$ATLAS_OP_FILE" "$run_dir")"
	atlas_ledger_append_current "tool.completed" "active-recon" "wiremap" "ok" "workflow=$workflow run_dir=$run_dir"
	record_operation_history "$ATLAS_OP_DIR" "recon:$workflow" "$run_dir"

	printf 'operation_recon_run: %s\n' "$run_dir"
	printf 'operation_recon_link: %s\n' "$link"
}

resolve_operation_capture_input() {
	local input="${1:-latest}"
	local latest

	load_active_operation

	if [ -z "$input" ] || [ "$input" = "latest" ]; then
		latest="$(latest_operation_recon_run)"
		[ -n "$latest" ] || fail "no recon run tracked for the active operation"
		printf '%s\n' "$latest"
		return 0
	fi

	printf '%s\n' "$input"
}

cmd_op_capture() {
	need_args 1 "$#" "op capture <inspect|streams|creds|anomalies> [run-dir-or-pcap|latest]"
	local mode="$1"
	local input="${2:-latest}"
	local resolved
	local output

	resolved="$(resolve_operation_capture_input "$input")"
	load_active_operation
	atlas_scope_preflight "read-only" "wiremap" "$ATLAS_OP_TARGET" "review captured evidence with $mode"
	output="$(run_wiremap capture "$mode" "$resolved")"
	printf '%s\n' "$output"
	atlas_ledger_append_current "tool.completed" "read-only" "wiremap" "ok" "capture=$mode source=$resolved"
	record_operation_history "$ATLAS_OP_DIR" "capture:$mode" "$resolved"
	printf 'operation_capture_source: %s\n' "$resolved"
}

cmd_op_action_candidates() {
	load_active_operation
	atlas_scope_preflight "read-only" "vector" "$ATLAS_OP_TARGET" "list action candidates"
	run_vector candidates "$ATLAS_OP_TARGET"
}

